# Network RPC URLs
# Get free RPC endpoints from https://alchemy.com or https://infura.io
POLYGON_AMOY_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_KEY   # testnet
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY      # mainnet
ARBITRUM_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
ARBITRUM_SEPOLIA_RPC_URL=https://arb-sepolia.g.alchemy.com/v2/YOUR_KEY

# Deployment wallet (never commit this!)
PRIVATE_KEY=your_deployer_wallet_private_key_here

# Fee collector address (receives platform fees from escrow)
FEE_COLLECTOR_ADDRESS=your_fee_collector_wallet_address_here

# Block Explorer API Keys (for contract verification)
# Polygonscan: https://polygonscan.com/myapikey
POLYGONSCAN_API_KEY=your_polygonscan_api_key
# Arbiscan: https://arbiscan.io/myapikey
ARBISCAN_API_KEY=your_arbiscan_api_key
